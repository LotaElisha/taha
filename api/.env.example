APP_NAME=Mkulima
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Dar_es_Salaam
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Postgres for production-grade JSON + FTS + geospatial.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mkulima
DB_USERNAME=mkulima
DB_PASSWORD=mkulima

# Sessions, cache, queues — all on Redis.
BROADCAST_CONNECTION=reverb
CACHE_STORE=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie
SESSION_LIFETIME=43200
SESSION_DOMAIN=localhost
SESSION_SECURE_COOKIE=false

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum SPA — the React frontend lives at localhost:3000 in dev.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,localhost:3002,127.0.0.1:3000,127.0.0.1:3001,127.0.0.1:3002
FRONTEND_URL=http://localhost:3000

# Reverb (websockets).
REVERB_APP_ID=mkulima-local
REVERB_APP_KEY=mkulima-local-key
REVERB_APP_SECRET=mkulima-local-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# SMS — Africa's Talking primary, Twilio fallback.
SMS_DEFAULT_DRIVER=africas-talking
AFRICAS_TALKING_USERNAME=sandbox
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SENDER_ID=Mkulima
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# Gemini — never expose this to the React bundle.
GEMINI_API_KEY=

# Cloudflare R2 for KYC docs + product images (private bucket, signed URLs).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=mkulima-private
AWS_ENDPOINT=https://<account>.r2.cloudflarestorage.com
AWS_USE_PATH_STYLE_ENDPOINT=true

# Payments — fill these with merchant credentials at deploy time.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_ENV=sandbox
# B2C payouts — separate Daraja initiator operator account.
MPESA_INITIATOR_NAME=
MPESA_INITIATOR_SECURITY_CREDENTIAL=
SELCOM_API_KEY=
SELCOM_API_SECRET=
SELCOM_VENDOR_ID=

# Meta WhatsApp Cloud API.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Sentry (server-side). React reads VITE_SENTRY_DSN from its own env.
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=

# Laravel Telescope is a dev-only debug UI. Off by default so its migrations
# aren't required for first run. Publish + migrate them if you want it on:
#   php artisan telescope:install
#   php artisan migrate
TELESCOPE_ENABLED=false

# Web Push — generate the pair once with `php artisan mkulima:vapid:gen`.
VAPID_SUBJECT=mailto:hello@mkulima.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Horizon dashboard credentials live entirely in DB-backed user accounts;
# only roles Admin + SuperAdmin can access /horizon (see HorizonServiceProvider).
